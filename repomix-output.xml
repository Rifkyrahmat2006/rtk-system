<file path="server/mcp-http.js">
import express from "express";
import dotenv from "dotenv";
import { runAgent } from "../agents/main-agent.js";

dotenv.config();

const app = express();

// Middleware untuk handle JSON error agar tidak crash
app.use(express.json());
app.use((err, req, res, next) => {
  if (err instanceof SyntaxError && err.status === 400 && "body" in err) {
    console.error("Bad JSON received:", err.message);
    return res.status(400).send({ error: "Invalid JSON" });
  }
  next();
});

// Landing page
app.get("/", (req, res) => {
  res.send("RTK MCP Server (SSE) is running! Use POST to /mcp for tool calls.");
});

app.get("/mcp", (req, res) => {
  res.send("MCP Endpoint is active. Please use POST method to interact.");
});

// ===== SSE ENDPOINT =====
app.post("/mcp", async (req, res) => {
  console.log(">>> Incoming Request:", req.body);

  // WAJIB untuk MCP
  res.setHeader("Content-Type", "text/event-stream");
  res.setHeader("Cache-Control", "no-cache");
  res.setHeader("Connection", "keep-alive");

  const { method, params } = req.body;

  function send(data) {
    res.write(`data: ${JSON.stringify(data)}\n\n`);
  }

  // Handle jika body kosong
  if (!method) {
    send({ error: "Method is required" });
    return res.end();
  }

  // ===== LIST TOOLS =====
  if (method === "tools/list") {
    send({
      tools: [
        {
          name: "rtk_ask",
          description: "Ask RTK about a project",
          input_schema: {
            type: "object",
            properties: {
              project: { type: "string" },
              prompt: { type: "string" }
            },
            required: ["project", "prompt"]
          }
        }
      ]
    });
    return res.end();
  }

  // ===== CALL TOOL =====
  if (method === "tools/call") {
    const { name, arguments: args } = params || {};

    if (name === "rtk_ask") {
      try {
        const result = await runAgent(args?.project, args?.prompt);
        send({
          content: [{ type: "text", text: result }]
        });
      } catch (err) {
        send({
          error: `Agent error: ${err.message}`
        });
      }
      return res.end();
    }
  }

  send({ error: `Unknown method: ${method}` });
  res.end();
});

app.listen(3000, () => {
  console.log("RTK MCP SSE running at http://localhost:3000/mcp");
});
